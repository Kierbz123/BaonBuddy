<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        Allow cleartext HTTP only for localhost / emulator addresses
        (Capacitor dev server, local backend during development).
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.171.0.75</domain>
    </domain-config>

    <!--
        Gemini API — must be reachable for Smart Insights, Voice Expenses,
        Anomaly Detection, and Burn-Rate Prediction features.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">generativelanguage.googleapis.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
        HuggingFace CDN — needed on first launch to download the ~90 MB
        MobileBERT model for offline auto-categorisation.
        After first download the model is cached and no further requests are made.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">huggingface.co</domain>
        <domain includeSubdomains="true">cdn-lfs.huggingface.co</domain>
        <domain includeSubdomains="true">cdn-lfs-us-1.huggingface.co</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
        Default: trust the system CA store + user-installed CAs.
        No cleartext allowed for any other domain.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

</network-security-config>
